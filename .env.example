# Database
DB_USER=beacon
DB_PASSWORD=beacon_dev
DB_NAME=beacon_crm

# For local development (running outside Docker):
DATABASE_URL=postgresql+asyncpg://beacon:beacon_dev@localhost:5432/beacon_crm
SYNC_DATABASE_URL=postgresql://beacon:beacon_dev@localhost:5432/beacon_crm
REDIS_URL=redis://localhost:6379/0

# NOTE: When running via `docker compose up`, the compose file automatically
# overrides the URLs above to use Docker-internal hostnames (postgres, redis).
# You do NOT need to change these for Docker — just use them as-is.

# App
SECRET_KEY=change_me_in_production
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
VITE_API_URL=http://localhost:8000

# Google OAuth (required for authentication)
# Setup: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# 1. Go to https://console.cloud.google.com and create/select a project
# 2. Enable "Google+ API" or "Google People API" under APIs & Services → Library
# 3. Go to APIs & Services → OAuth consent screen → Configure (External, add your email as test user)
# 4. Go to APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Authorized redirect URIs: http://localhost:8000/api/v1/auth/google/callback
# 7. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=change_me_to_a_random_string_in_production
JWT_EXPIRE_MINUTES=1440

# External API Keys (leave empty to use mock mode)
APOLLO_API_KEY=
HUNTER_API_KEY=
BUILTWITH_API_KEY=
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_URL=https://yourdomain.com/api/v1/webhooks/instantly
FIREFLIES_API_KEY=
NEWS_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Gmail shared inbox (email-to-activity tracking)
# 1. Go to Google Cloud Console → APIs & Services → Library → Enable "Gmail API"
# 2. Create OAuth 2.0 credentials (same project as Google OAuth above)
# 3. Download credentials JSON and place it at the path below
# 4. Run: python -m app.clients.gmail_inbox  (one-time auth flow, saves token.json)
GMAIL_SHARED_INBOX=sales@yourcompany.com
GMAIL_CREDENTIALS_JSON=gmail_credentials.json
GMAIL_TOKEN_JSON=gmail_token.json
EMAIL_SYNC_INTERVAL_SECONDS=180
EMAIL_SUMMARY_MIN_CHARS=100

# tl;dv meeting intelligence
TLDV_API_KEY=
TLDV_API_BASE=https://pasta.tldv.io/v1alpha1
TLDV_SYNC_LOOKBACK_DAYS=365
